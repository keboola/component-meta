{
  "authorization": {
    "oauth_api": {
      "credentials": {
        "id": "my-oauth-credentials",
        "authorizedFor": "My Facebook Page",
        "#data": "{\"access_token\": \"YOUR_ACCESS_TOKEN\"}",
        "oauthVersion": "facebook",
        "appKey": "YOUR_APP_ID",
        "#appSecret": "YOUR_APP_SECRET"
      }
    }
  },
  "parameters": {
    "accounts": {
      "123456789": {
        "id": "123456789",
        "name": "My Facebook Page",
        "category": "Company"
      }
    },
    "api-version": "v23.0",
    "queries": [
      {
        "id": 1,
        "type": "nested-query",
        "name": "page_insights_daily",
        "run-by-id": false,
        "query": {
          "fields": "insights.since(30 days ago).time_increment(1).metric(page_impressions, page_impressions_unique, page_views_total, page_fans, page_fan_adds, page_fan_removes, page_post_engagements)",
          "ids": "",
          "limit": "25",
          "path": ""
        }
      },
      {
        "id": 2,
        "type": "nested-query",
        "name": "feed_post_insights",
        "run-by-id": false,
        "query": {
          "fields": "message, created_time, permalink_url, insights.metric(post_impressions, post_impressions_unique, post_clicks, post_reactions_like_total).period(lifetime){name, values}",
          "ids": "",
          "limit": "25",
          "path": "feed",
          "since": "30 days ago",
          "until": "today"
        }
      },
      {
        "id": 3,
        "type": "nested-query",
        "name": "feed_post_media_view_by_source",
        "run-by-id": false,
        "query": {
          "fields": "insights.metric(post_media_view).breakdown(is_from_ads).period(lifetime)",
          "ids": "",
          "limit": "25",
          "path": "feed",
          "since": "30 days ago",
          "until": "today"
        }
      },
      {
        "id": 4,
        "type": "nested-query",
        "name": "page_basic_info",
        "run-by-id": false,
        "query": {
          "fields": "fan_count, followers_count, name",
          "ids": "",
          "limit": "25",
          "path": ""
        }
      }
    ],
    "bucket-id": "in.c-keboola-ex-facebook-pages"
  }
}
